# ── Gemini API (bắt buộc cho tính năng Chat AI) ──────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Flask ────────────────────────────────────────────────────
# Để false khi chạy thật. Bật true chỉ khi dev.
FLASK_DEBUG=false
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
# Cross-origin: để trống nếu frontend chạy cùng origin với backend (mặc định).
# Chỉ đặt khi frontend ở domain khác. Phân tách nhiều origin bằng dấu phẩy.
# Ví dụ: CORS_ORIGINS=https://shopsmart.example.com
CORS_ORIGINS=

# ── Rate limiting (số request tối đa mỗi 60 giây) ────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH=10
RATE_LIMIT_CHAT=20
RATE_LIMIT_SEARCH=30
RATE_LIMIT_REFRESH=6

# ── Bộ nhớ phiên chat AI (giới hạn LRU + TTL) ────────────────
# Số phiên agent tối đa giữ trong RAM và thời gian sống (giây).
AGENT_CACHE_MAX=200
AGENT_CACHE_TTL=7200

# ── Auth / JWT ───────────────────────────────────────────────
# BẮT BUỘC đặt cho production. Nếu để trống, app tự sinh và lưu vào .jwt_secret (chỉ hợp cho dev).
JWT_SECRET=
# Thời hạn token (giây). Mặc định 7 ngày.
JWT_EXPIRY_SECONDS=604800
# bcrypt work factor (4-15). Mặc định 12.
BCRYPT_ROUNDS=12

# ── Price Monitor (tự động cập nhật giá nền) ─────────────────
PRICE_MONITOR_ENABLED=true
# Chu kỳ quét (giây). Mặc định 6 giờ.
PRICE_MONITOR_INTERVAL=21600
PRICE_MONITOR_INITIAL_DELAY=60
PRICE_MONITOR_PER_ITEM_DELAY=3
# Có chạy monitor ngay trong tiến trình web không.
# Khi chạy nhiều worker (gunicorn -w N): đặt false và chạy riêng `python monitor.py`
# để tránh mỗi worker spawn một monitor và quét trùng.
PRICE_MONITOR_IN_PROCESS=true

# ── Production server (waitress) ─────────────────────────────
# Dùng `python serve.py` để chạy WSGI server thật thay cho dev server (app.py).
SERVE_HOST=0.0.0.0
SERVE_THREADS=8

# ── Thông báo thật: Telegram (tùy chọn) ──────────────────────
# Token bot Telegram. Mỗi user nhập chat_id của mình trong phần cài đặt.
TELEGRAM_BOT_TOKEN=

# ── Thông báo thật: Email SMTP (tùy chọn) ────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Scraper: giới hạn tải về từ URL không tin cậy ───────────
# Kích thước tối đa (byte) của nội dung khi scrape. Mặc định 5MB.
SCRAPE_MAX_RESPONSE_BYTES=5242880

# ── Tìm kiếm: cache + rate-limit (tránh bị DuckDuckGo chặn 429) ─
# Thời gian cache kết quả tìm kiếm (giây). Mặc định 5 phút.
SEARCH_CACHE_TTL=300
# Số lần gọi tìm kiếm tối đa trong mỗi khoảng SEARCH_RATE_PERIOD.
SEARCH_RATE_MAX_CALLS=8
SEARCH_RATE_PERIOD=60
